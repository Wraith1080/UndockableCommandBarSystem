<Window x:Class="CommandBar.UI.Dialogs.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
        Title="Customize Toolbars" Height="550" Width="580"
        WindowStyle="ToolWindow" ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CommandBar.UI;component/CommandBarTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl>

            <TabItem Header="Toolbars">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="ToolbarListBox" ItemsSource="{Binding AllToolbars}" Margin="0,0,10,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible, Mode=TwoWay}" Margin="2" Cursor="Hand"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Column="1">
                        <Button Content="New..." Click="NewToolbar_Click" Margin="0,0,0,5" Padding="4"/>
                        <Button Content="Rename..." Click="RenameToolbar_Click" Margin="0,0,0,5" Padding="4"/>
                        <Button Content="Delete" Click="DeleteToolbar_Click" Margin="0,0,0,15" Padding="4"/>
                        <Button Content="Reset" Click="ResetToolbar_Click" Padding="4"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Commands">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Select a command to edit, or drag it to a toolbar:" FontWeight="SemiBold" Margin="0,0,0,10" Grid.ColumnSpan="2"/>

                    <ListBox x:Name="MasterCommandList" Grid.Row="1" Grid.Column="0" Margin="0,0,15,0"
                             ItemsSource="{Binding AvailableCommands}"
                             PreviewMouseLeftButtonDown="MasterCommandList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="MasterCommandList_PreviewMouseMove">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CommandItem}">
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}" 
                                                    Width="16" Height="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Text}" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1" Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" CornerRadius="4">
                        <Grid>
                            <TextBlock Text="Select a command from the list to edit its properties." TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, ElementName=MasterCommandList}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel DataContext="{Binding SelectedItem, ElementName=MasterCommandList}">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Command Properties" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <TextBlock Text="Label:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4"/>

                                <TextBlock Text="Tooltip:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Tooltip, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4"/>

                                <TextBlock Text="SVG Icon Path Data:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                <Grid Margin="0,2,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding IconGeometry, UpdateSourceTrigger=PropertyChanged}" 
                                             Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                             Padding="4" FontFamily="Consolas" FontSize="10"/>

                                    <Button Grid.Column="1" Content="Browse..." Width="65" Height="26" Margin="5,0,0,0" 
                                            VerticalAlignment="Top" Click="BrowseSvg_Click" Cursor="Hand"/>
                                </Grid>

                                <TextBlock Text="Live Preview:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                
                                <Border BorderBrush="#D4D4D4" BorderThickness="1" Background="White" Width="48" Height="48" HorizontalAlignment="Left" CornerRadius="4" Margin="0,5,0,0">
                                    <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}" 
                                                    Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="Reset Command to Default" Width="160" Height="26" Margin="0,15,0,0" 
                                        HorizontalAlignment="Left" Click="ResetCommand_Click" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
        <Grid x:Name="InputOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="White" Width="260" Height="130" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="15" CornerRadius="4">
                <StackPanel>
                    <TextBlock x:Name="InputPromptText" Text="Enter name:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBox x:Name="InputTextBox" Margin="0,0,0,15" Padding="2"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="OK" Width="60" Click="InputOk_Click" Margin="0,0,5,0"/>
                        <Button Content="Cancel" Width="60" Click="InputCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>