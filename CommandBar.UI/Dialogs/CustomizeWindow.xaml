<Window x:Class="CommandBar.UI.Dialogs.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
        Title="Customize Toolbars" Height="640" Width="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CommandBar.UI;component/CommandBarTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
    </Window.Resources>
    <Border Padding="12">

        <Border Background="{DynamicResource CmdBar.Background}" 
                BorderBrush="{DynamicResource CmdBar.Border}" 
                BorderThickness="1"
                CornerRadius="{DynamicResource CmdBar.Window.CornerRadius}"
                Effect="{DynamicResource CmdBar.Menu.Shadow}">

            <DockPanel>

                <Border DockPanel.Dock="Top" Height="32" Background="Transparent" 
                        Cursor="SizeAll" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="Customize Toolbars" 
                                   VerticalAlignment="Center" 
                                   Margin="12,0" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource CmdBar.Foreground}"/>

                        <Button HorizontalAlignment="Right" Width="40" Focusable="False" Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Customize.CloseButtonCornerRadius}" Cursor="Arrow">
                                        <Path x:Name="CloseIcon" Data="{DynamicResource CmdBar.Customize.CloseButtonIcon}" 
                                              Stroke="{DynamicResource CmdBar.Foreground}" 
                                              StrokeThickness="1" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Background" Value="#E81123"/>
                                            <Setter TargetName="CloseIcon" Property="Stroke" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Grid Margin="10">
                    <TabControl>

                        <TabItem Header="Toolbars">
                            <Grid Margin="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <ListBox x:Name="ToolbarListBox" ItemsSource="{Binding AllToolbars}" Margin="0,0,10,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible, Mode=TwoWay}" Margin="2" Cursor="Hand"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Column="1">
                                    <Button Content="New..." Click="NewToolbar_Click" Margin="0,0,0,5" Padding="4"/>
                                    <Button Content="Rename..." Click="RenameToolbar_Click" Margin="0,0,0,5" Padding="4"/>
                                    <Button Content="Delete" Click="DeleteToolbar_Click" Margin="0,0,0,15" Padding="4"/>
                                    <Button Content="Reset" Click="ResetToolbar_Click" Padding="4"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Commands">
                            <Grid Margin="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <TextBlock Text="Select a command to edit, or drag items to your toolbars:" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <TextBlock Text="UI Elements:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>

                                    <Border x:Name="DraggableSeparatorTool" Background="#F4F4F4" BorderBrush="#D4D4D4" BorderThickness="1" 
                            CornerRadius="3" Padding="8,4" Margin="0,2,0,15" Width="130" HorizontalAlignment="Left" Cursor="Hand"
                            PreviewMouseLeftButtonDown="DraggableSeparatorTool_MouseDown"
                            PreviewMouseMove="DraggableSeparatorTool_MouseMove"
                            ToolTip="Drag this block onto a toolbar to create a separator line.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➖" Margin="0,0,8,0" Foreground="Gray"/>
                                            <TextBlock Text="Separator Line" Foreground="#333" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Available Commands:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                </StackPanel>

                                <ListBox x:Name="MasterCommandList" Grid.Row="1" Grid.Column="0" Margin="0,0,15,0"
                         ItemsSource="{Binding AvailableCommands}"
                         PreviewMouseLeftButtonDown="MasterCommandList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="MasterCommandList_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:CommandItem}">
                                            <StackPanel Orientation="Horizontal" Margin="4">
                                                <Grid Width="16" Height="16" Margin="0,0,10,0">
                                                    <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}">
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                                <TextBlock Text="{Binding Text}" VerticalAlignment="Center" FontSize="14"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Grid.Row="1" Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" CornerRadius="4">
                                    <Grid>
                                        <TextBlock Text="Select a command from the list to edit its properties." TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=MasterCommandList}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel DataContext="{Binding SelectedItem, ElementName=MasterCommandList}">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="Command Properties" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                            <TextBlock Text="Label:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4"/>

                                            <TextBlock Text="Tooltip:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding Tooltip, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4"/>

                                            <TextBlock Text="SVG Icon Path Data:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>
                                            <Grid Margin="0,2,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Text="{Binding IconGeometry, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                                         Padding="4" FontFamily="Consolas" FontSize="10"/>

                                                <Button Grid.Column="1" Content="Browse..." Width="65" Height="26" Margin="5,0,0,0" 
                                        VerticalAlignment="Top" Click="BrowseSvg_Click" Cursor="Hand"/>
                                            </Grid>

                                            <TextBlock Text="Live Preview:" FontSize="11" Foreground="#555" FontWeight="SemiBold"/>

                                            <Border BorderBrush="#D4D4D4" BorderThickness="1" Background="White" Width="48" Height="48" HorizontalAlignment="Left" CornerRadius="4" Margin="0,5,0,0">
                                                <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}">
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                            </Border>
                                            <CheckBox IsChecked="{Binding KeepOriginalColors}" Content="Keep Original Colors" Margin="0,15,0,0"/>
                                            <Button Content="Reset Command to Default" Width="160" Height="26" Margin="0,15,0,0" 
                                    HorizontalAlignment="Left" Click="ResetCommand_Click" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Main Menu">
                            <Grid Margin="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <Border BorderBrush="#D4D4D4" BorderThickness="1" CornerRadius="2">
                                    <TreeView x:Name="MenuTreeView" ItemsSource="{Binding MainMenuBar.DockedItems}" BorderThickness="0" Padding="5">
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type models:CommandDropdownItem}" ItemsSource="{Binding ChildItems}">
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="📁" Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Text}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </HierarchicalDataTemplate>

                                            <DataTemplate DataType="{x:Type models:CommandItem}">
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="📄" Margin="0,0,5,0" Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Text}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                            <DataTemplate DataType="{x:Type models:CommandSeparator}">
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="➖" Margin="0,0,5,0" Foreground="LightGray"/>
                                                    <TextBlock Text="----------- (Separator) -----------" Foreground="Gray" FontStyle="Italic"/>
                                                </StackPanel>
                                            </DataTemplate>
                                            <DataTemplate DataType="{x:Type models:CommandToggleItem}">
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="☑️" Margin="0,0,5,0" Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Text}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                    <TextBlock Text="Menu Structure" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <Button Content="Add Root Menu..." Click="AddMenuRoot_Click" Margin="0,0,0,5" Padding="4" Cursor="Hand" ToolTip="Adds a new menu like 'File' or 'Edit' to the top bar."/>
                                    <Button Content="Add Sub-Menu Folder..." Click="AddSubMenu_Click" Margin="0,0,0,15" Padding="4" Cursor="Hand" ToolTip="Adds a folder inside the selected menu."/>

                                    <TextBlock Text="Add Command to Selected Menu:" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="MenuCommandPicker" ItemsSource="{Binding AvailableCommands}" DisplayMemberPath="Text" Margin="0,0,0,5" Padding="4"/>
                                    <Button Content="Insert Command" Click="InsertMenuCommand_Click" Margin="0,0,0,5" Padding="4" Cursor="Hand"/>

                                    <Button Content="Insert Separator" Click="InsertSeparator_Click" Margin="0,0,0,15" Padding="4" Cursor="Hand"/>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Move Up 🔼" Click="MoveUp_Click" Padding="4"/>
                                        <Button Grid.Column="2" Content="Move Down 🔽" Click="MoveDown_Click" Padding="4"/>
                                    </Grid>

                                    <Separator Margin="0,0,0,10"/>

                                    <Button Content="Reset Selected Root Menu" Click="ResetMenu_Click" Margin="0,0,0,5" Padding="4"/>
                                    <Button Content="Remove Selected Item" Click="RemoveMenuItem_Click" Foreground="DarkRed" Padding="4" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Appearance">
                            <StackPanel Margin="20">
                                <TextBlock Text="Application Theme" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="{DynamicResource CmdBar.Foreground}"/>
                                <TextBlock Text="Choose the visual style for the toolbars and menus:" Opacity="0.7" Margin="0,0,0,15" Foreground="{DynamicResource CmdBar.Foreground}"/>

                                <RadioButton x:Name="ThemeModernRadio" 
                         Content="Modern (Fluent Design)" 
                         IsChecked="True" 
                         Margin="10,5" 
                         Checked="ThemeRadio_Checked"
                         Foreground="{DynamicResource CmdBar.Foreground}"/>

                                <RadioButton x:Name="ThemeClassicRadio" 
                         Content="Classic (Office 2003)" 
                         Margin="10,5" 
                         Checked="ThemeRadio_Checked"
                         Foreground="{DynamicResource CmdBar.Foreground}"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    <Grid x:Name="InputOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
                        <Border Background="White" Width="260" Height="130" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="15" CornerRadius="4">
                            <StackPanel>
                                <TextBlock x:Name="InputPromptText" Text="Enter name:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBox x:Name="InputTextBox" Margin="0,0,0,15" Padding="2"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="OK" Width="60" Click="InputOk_Click" Margin="0,0,5,0"/>
                                    <Button Content="Cancel" Width="60" Click="InputCancel_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>
    </Border>
    
</Window>