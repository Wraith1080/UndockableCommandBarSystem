<Window x:Class="CommandBar.UI.Dialogs.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
        Title="Customize Toolbars" Height="450" Width="300"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Drag commands to your toolbars:" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <ListBox x:Name="MasterCommandList" Grid.Row="1" 
                 ItemsSource="{Binding RegisteredCommands}"
                 PreviewMouseLeftButtonDown="MasterCommandList_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="MasterCommandList_PreviewMouseMove">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:CommandItem}">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Path Data="{Binding IconGeometry, Converter={StaticResource PathConverter}, FallbackValue={x:Null}}" 
                              Fill="#444" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Text}" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>