<Window x:Class="CommandBar.UI.Dialogs.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
        Title="Customize Toolbars" Height="450" Width="380"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CommandBar.UI;component/CommandBarTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl>

            <TabItem Header="Toolbars">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Create a New Custom Toolbar:" FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBox x:Name="NewToolbarNameBox" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center" />
                        <Button Content="New..." Width="80" Padding="4,2" Click="CreateNewToolbar_Click" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" TextWrapping="Wrap" Foreground="Gray" FontStyle="Italic"
                               Text="Type a name above and click 'New...' to spawn a blank custom toolbar. You can then drag commands into it from the Commands tab!"/>
                </Grid>
            </TabItem>

            <TabItem Header="Commands">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Drag commands to your toolbars:" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <ListBox x:Name="MasterCommandList" Grid.Row="1" 
                             ItemsSource="{Binding AvailableCommands}"
                             PreviewMouseLeftButtonDown="MasterCommandList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="MasterCommandList_PreviewMouseMove">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CommandItem}">
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}" 
                                                    Width="16" Height="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Text}" VerticalAlignment="Center" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>