<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
                    xmlns:controls="clr-namespace:CommandBar.UI.Controls">

    <controls:StringToPathConverter x:Key="PathConverter" />
    <controls:RawSvgConverter x:Key="RawSvgConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    <Style TargetType="Button" x:Key="CommandButtonStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource CmdBar.Foreground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
        BorderBrush="{TemplateBinding BorderBrush}" 
        BorderThickness="{TemplateBinding BorderThickness}" 
        CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center" x:Name="ContentHost"
                      VerticalAlignment="Center" 
                      Margin="{DynamicResource CmdBar.Button.Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ToolBar}}" Value="Vertical">
                            <Setter TargetName="ContentHost" Property="Margin" Value="{DynamicResource CmdBar.Button.Padding.Vertical}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Pressed.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Pressed.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToggleButton" x:Key="CommandToggleButtonStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource CmdBar.Foreground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" 
        BorderBrush="{TemplateBinding BorderBrush}" 
        BorderThickness="{TemplateBinding BorderThickness}" 
        CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center" 
                      VerticalAlignment="Center" 
                      Margin="{DynamicResource CmdBar.Button.Padding}" x:Name="ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ToolBar}}" Value="Vertical">
                            <Setter TargetName="ContentHost" Property="Margin" Value="{DynamicResource CmdBar.Button.Padding.Vertical}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Checked.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Grid x:Key="DualMenuIcon" x:Shared="False" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}">
        <Path Data="{Binding IconGeometry}" Fill="{DynamicResource CmdBar.IconFill}" Stretch="Uniform">
            <Path.Style>
                <Style TargetType="Path">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Path.Style>
        </Path>
        <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}" Width="{DynamicResource CmdBar.IconSize}"
       Height="{DynamicResource CmdBar.IconSize}">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
    </Grid>

    <Style x:Key="NativeMenuBarItemStyle" TargetType="MenuItem">
        <Setter Property="Header" Value="{Binding Text}"/>
        <Setter Property="ItemsSource" Value="{Binding ChildItems}"/>
        <Setter Property="Command" Value="{Binding ExecuteItemCommand}"/>
        <Setter Property="Icon" Value="{StaticResource DualMenuIcon}"/>
        <Setter Property="InputGestureText" Value="{Binding ShortcutText}"/>
        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
        <Setter Property="ItemContainerStyle" Value="{Binding ItemContainerStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="RootBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}">
                                <Grid>
                                    <ContentPresenter x:Name="HeaderHost" ContentSource="Header" Margin="{DynamicResource CmdBar.Button.Padding}" RecognizesAccessKey="True"/>
                                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" VerticalOffset="{DynamicResource CmdBar.Menu.PopupOffset}" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">
                                        <Border Background="{DynamicResource CmdBar.Background}" BorderBrush="{DynamicResource CmdBar.Border}" BorderThickness="1" CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}" Padding="2" Margin="{DynamicResource CmdBar.Menu.ShadowMargin}" Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="500" BorderThickness="0">
                                                <ItemsPresenter Grid.IsSharedSizeScope="True" />
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" Margin="2,1">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="IconColumnGroup" MinWidth="{DynamicResource CmdBar.IconSize}" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,8,0" ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="16,0,0,0" Opacity="0.6" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" Margin="2,1">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="IconColumnGroup" MinWidth="{DynamicResource CmdBar.IconSize}" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="0,0,8,0" ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="16,0,0,0" Opacity="0.6" VerticalAlignment="Center"/>

                                    <Path x:Name="SubmenuArrow" Grid.Column="3" Data="M 0,0 L 4,4 L 0,8 Z" Fill="{DynamicResource CmdBar.Foreground}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>

                                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right" VerticalOffset="-4" HorizontalOffset="{DynamicResource CmdBar.Menu.PopupOffset}" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">
                                        <Border Background="{DynamicResource CmdBar.Background}" BorderBrush="{DynamicResource CmdBar.Border}" BorderThickness="1" CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}" Padding="2" Margin="{DynamicResource CmdBar.Menu.ShadowMargin}" Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="500" BorderThickness="0">
                                                <ItemsPresenter Grid.IsSharedSizeScope="True" />
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="IconColumnGroup" MinWidth="{DynamicResource CmdBar.IconSize}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="1" Height="1" Fill="{DynamicResource CmdBar.Border}" Margin="0,0,2,0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>

            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter Property="Icon" Value="{x:Null}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type models:CommandItem}">
        <Button x:Name="RootButton" Style="{StaticResource CommandButtonStyle}" Command="{Binding ExecuteItemCommand}" Focusable="False" ToolTip="{Binding Tooltip}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Grid x:Name="IconPath" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}" Margin="0,0,4,0">

                    <Path Data="{Binding IconGeometry}" Fill="{DynamicResource CmdBar.IconFill}" Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                </Grid>
                <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandToggleItem}">
        <ToggleButton x:Name="RootButton" Style="{StaticResource CommandToggleButtonStyle}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Command="{Binding ExecuteItemCommand}" Focusable="False" ToolTip="{Binding Tooltip}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Grid x:Name="IconPath" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}" Margin="0,0,4,0">

                    <Path Data="{Binding IconGeometry}" Fill="{DynamicResource CmdBar.IconFill}" Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                </Grid>
                <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </ToggleButton>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandSeparator}">
        <Border x:Name="SepBorder" 
            Width="1" 
            Background="{DynamicResource CmdBar.Border}" 
            Margin="2,4" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Stretch"
            Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ToolBar}, Path=Orientation}" Value="Vertical">
                <Setter TargetName="SepBorder" Property="Width" Value="NaN"/>
                <Setter TargetName="SepBorder" Property="Height" Value="1"/>

                <Setter TargetName="SepBorder" Property="Margin" Value="4,2"/>

                <Setter TargetName="SepBorder" Property="HorizontalAlignment" Value="Stretch"/>
                <Setter TargetName="SepBorder" Property="VerticalAlignment" Value="Center"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandDropdownItem}">
        <Menu x:Name="RootMenu" Background="Transparent" Margin="{DynamicResource CmdBar.Menu.Margin}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <MenuItem Focusable="False" Padding="{DynamicResource CmdBar.Button.Padding}" ItemsSource="{Binding ChildItems}" x:Name="RootMenuItem">

                <MenuItem.Template>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder" 
                            Background="Transparent" 
                            BorderBrush="Transparent" 
                            BorderThickness="1" 
                            CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}">
                            <Grid>
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>

                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" 
       VerticalOffset="{DynamicResource CmdBar.Menu.PopupOffset}" 
       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">

                                    <Border Background="{DynamicResource CmdBar.Background}" 
            BorderBrush="{DynamicResource CmdBar.Border}" 
            BorderThickness="1" 
            CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}" 
            Padding="2" Margin="{DynamicResource CmdBar.Menu.ShadowMargin}"
            Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">

                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="500" BorderThickness="0">
                                            <ItemsPresenter Grid.IsSharedSizeScope="True" />
                                        </ScrollViewer>

                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Padding" Value="{DynamicResource CmdBar.Button.Padding}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Role" Value="TopLevelHeader" />
                                    <Condition Property="IsHighlighted" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
                            </MultiTrigger>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Checked.Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </MenuItem.Template>

                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Grid x:Name="IconPath" Margin="0,0,4,0">
                            <Path Data="{Binding IconGeometry}" 
      Fill="{DynamicResource CmdBar.IconFill}" 
      Stretch="Uniform" 
      Width="{DynamicResource CmdBar.IconSize}" 
      Height="{DynamicResource CmdBar.IconSize}">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}" Width="{DynamicResource CmdBar.IconSize}" Height="{DynamicResource CmdBar.IconSize}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                        <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>

                        <Path x:Name="DropdownArrow" 
                          Data="{DynamicResource CmdBar.Menu.DropdownArrow}" 
                          Fill="{DynamicResource CmdBar.Foreground}" 
                          VerticalAlignment="Center" Margin="4,2,0,0"/>
                    </StackPanel>
                </MenuItem.Header>

                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Text}"/>
                        <Setter Property="Command" Value="{Binding ExecuteItemCommand}"/>
                        <Setter Property="InputGestureText" Value="{Binding ShortcutText}"/>
                        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                        <Setter Property="Icon" Value="{StaticResource DualMenuIcon}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="ItemBorder" Background="Transparent" 
                                        CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" 
                                        Margin="2,1">
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IconColumnGroup" MinWidth="{DynamicResource CmdBar.IconSize}" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ContentPresenter Margin="0,0,8,0" ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                            <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="16,0,0,0" Opacity="0.6" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </MenuItem.ItemContainerStyle>

            </MenuItem>
        </Menu>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical">
                <Setter TargetName="RootMenuItem" Property="Padding" Value="{DynamicResource CmdBar.Button.Padding.Vertical}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootMenu" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>