<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
                    xmlns:controls="clr-namespace:CommandBar.UI.Controls">

    <controls:StringToPathConverter x:Key="PathConverter" />
    <controls:RawSvgConverter x:Key="RawSvgConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    <Style TargetType="Button" x:Key="CommandButtonStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource CmdBar.Foreground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Pressed.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Pressed.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToggleButton" x:Key="CommandToggleButtonStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource CmdBar.Foreground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Checked.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Grid x:Key="DualMenuIcon" x:Shared="False" Width="16" Height="16">
        <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
        <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
            <Image.Style>
                <Style TargetType="Image">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Image.Style>
        </Image>
    </Grid>

    <Style x:Key="NativeMenuBarItemStyle" TargetType="MenuItem">
        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="Transparent"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
        </Style.Resources>

        <Setter Property="Header" Value="{Binding Text}"/>
        <Setter Property="ItemsSource" Value="{Binding ChildItems}"/>
        <Setter Property="Command" Value="{Binding ExecuteItemCommand}"/>
        <Setter Property="Icon" Value="{StaticResource DualMenuIcon}"/>
        <Setter Property="InputGestureText" Value="{Binding ShortcutText}"/>
        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>

        <Setter Property="ItemContainerStyle" Value="{Binding ItemContainerStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Separator Style="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>

            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter Property="Icon" Value="{x:Null}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type models:CommandItem}">
        <Button x:Name="RootButton" Style="{StaticResource CommandButtonStyle}" Command="{Binding ExecuteItemCommand}" Focusable="False" ToolTip="{Binding Tooltip}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Grid x:Name="IconPath" Width="16" Height="16" Margin="0,0,4,0">

                    <Path Data="{Binding IconGeometry}" Fill="{DynamicResource CmdBar.IconFill}" Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                </Grid>
                <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandToggleItem}">
        <ToggleButton x:Name="RootButton" Style="{StaticResource CommandToggleButtonStyle}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Command="{Binding ExecuteItemCommand}" Focusable="False" ToolTip="{Binding Tooltip}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <Grid x:Name="IconPath" Width="16" Height="16" Margin="0,0,4,0">

                    <Path Data="{Binding IconGeometry}" Fill="{DynamicResource CmdBar.IconFill}" Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                </Grid>
                <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </ToggleButton>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandSeparator}">
        <Border Width="1" Background="{DynamicResource CmdBar.Border}" Margin="2,4" 
                HorizontalAlignment="Center" VerticalAlignment="Stretch"
                Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandDropdownItem}">
        <Menu x:Name="RootMenu" Background="Transparent" Margin="1" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <MenuItem Focusable="False" Padding="4,2" ItemsSource="{Binding ChildItems}">

                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Grid x:Name="IconPath" Width="16" Height="16" Margin="0,0,4,0">
                            <ContentControl Content="{Binding IconGeometry, Converter={StaticResource PathConverter}}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KeepOriginalColors}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                            <Image Source="{Binding RawSvgContent, Converter={StaticResource RawSvgConverter}}">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding KeepOriginalColors}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                        <AccessText x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>

                        <Path x:Name="DropdownArrow" Data="M 0,0 L 4,4 L 8,0 Z" Fill="{DynamicResource CmdBar.IconFill}" VerticalAlignment="Center" Margin="4,2,0,0"/>
                    </StackPanel>
                </MenuItem.Header>

                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Text}"/>
                        <Setter Property="Command" Value="{Binding ExecuteItemCommand}"/>
                        <Setter Property="InputGestureText" Value="{Binding ShortcutText}"/>
                        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                        <Setter Property="Icon" Value="{StaticResource DualMenuIcon}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>

            </MenuItem>
        </Menu>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootMenu" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>