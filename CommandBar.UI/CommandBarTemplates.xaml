<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core"
                    xmlns:controls="clr-namespace:CommandBar.UI.Controls">

    <DataTemplate DataType="{x:Type models:CommandItem}">
        <Button x:Name="RootButton" Command="{Binding ExecuteItemCommand}" Focusable="False" ToolTip="{Binding Tooltip}" 
                Background="Transparent" BorderThickness="0" Margin="1" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Path x:Name="IconPath" Data="{Binding IconGeometry}" Fill="#444" Width="16" Height="16" Stretch="Uniform" Margin="0,0,4,0"/>
                <TextBlock x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandToggleItem}">
        <ToggleButton x:Name="RootButton" IsChecked="{Binding IsChecked, Mode=TwoWay}" Command="{Binding ExecuteItemCommand}" 
                      Focusable="False" ToolTip="{Binding Tooltip}" Background="Transparent" BorderThickness="0" Margin="1" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Path x:Name="IconPath" Data="{Binding IconGeometry}" Fill="#444" Width="16" Height="16" Stretch="Uniform" Margin="0,0,4,0"/>
                <TextBlock x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </ToggleButton>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootButton" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandSeparator}">
        <Separator Width="1" Margin="2,4" Background="#CCC"/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandDropdownItem}">
        <Menu x:Name="RootMenu" Background="Transparent" Margin="1">
            <MenuItem Focusable="False" Padding="4,2" ItemsSource="{Binding ChildItems}">

                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path x:Name="IconPath" Data="{Binding IconGeometry}" Fill="#444" Width="16" Height="16" Stretch="Uniform" Margin="0,0,4,0"/>
                        <TextBlock x:Name="LabelText" Text="{Binding Text}" VerticalAlignment="Center"/>

                        <Path x:Name="DropdownArrow" Data="M 0,0 L 4,4 L 8,0 Z" Fill="#444" VerticalAlignment="Center" Margin="4,2,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:UndockableToolBar}}, Path=IsMenuBar}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </StackPanel>
                </MenuItem.Header>

                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Text}"/>
                        <Setter Property="Command" Value="{Binding ExecuteItemCommand}"/>
                        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                        <Setter Property="Icon">
                            <Setter.Value>
                                <Path Data="{Binding IconGeometry}" Fill="#444" Width="16" Height="16" Stretch="Uniform"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </MenuItem.ItemContainerStyle>

            </MenuItem>
        </Menu>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding DisplayMode}" Value="ImageOnly">
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </DataTrigger>
            <DataTrigger Binding="{Binding DisplayMode}" Value="TextOnly">
                <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="ImageAndText" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="IconPath" Property="Margin" Value="0" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}, Path=Orientation}" Value="Vertical" />
                    <Condition Binding="{Binding DisplayMode}" Value="TextOnly" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="RootMenu" Property="ToolBar.OverflowMode" Value="Always" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>