<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:CommandBar.Core.Models;assembly=CommandBar.Core">

    <DataTemplate DataType="{x:Type models:CommandItem}">
        <Button Command="{Binding ExecuteItemCommand}" 
                Focusable="False"
                ToolTip="{Binding Tooltip}"
                Margin="1" Padding="4,2"
                Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
                <Viewbox Width="16" Height="16" Margin="0,0,4,0">
                    <Path Data="{Binding IconGeometry}" 
                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" 
                          Stretch="Uniform" />
                </Viewbox>

                <TextBlock Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandToggleItem}">
        <ToggleButton IsChecked="{Binding IsChecked, Mode=TwoWay}"
                      Command="{Binding ExecuteItemCommand}" 
                      Focusable="False"
                      ToolTip="{Binding Tooltip}"
                      Margin="1" Padding="4,2"
                      Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
                <Viewbox Width="16" Height="16" Margin="0,0,4,0">
                    <Path Data="{Binding IconGeometry}" 
                          Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" 
                          Stretch="Uniform" />
                </Viewbox>

                <TextBlock Text="{Binding Text}" VerticalAlignment="Center"/>
            </StackPanel>
        </ToggleButton>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandSeparator}">
        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type models:CommandDropdownItem}">
        <Menu Background="Transparent">
            <MenuItem Header="{Binding Text}" Focusable="False" ItemsSource="{Binding ChildItems}" ToolTip="{Binding Tooltip}" Padding="4">
                <MenuItem.Icon>
                    <Viewbox Width="16" Height="16">
                        <Path Data="{Binding IconGeometry}" Fill="Black" Stretch="Uniform" />
                    </Viewbox>
                </MenuItem.Icon>
            </MenuItem>
        </Menu>
    </DataTemplate>

</ResourceDictionary>