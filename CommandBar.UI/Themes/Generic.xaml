<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CommandBar.UI.Controls"
    xmlns:local="clr-namespace:CommandBar.UI">
    <Style TargetType="{x:Type controls:UndockableToolBar}">

        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}" Value="Horizontal" />
                </MultiDataTrigger.Conditions>
                <Setter Property="MinWidth" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ToolBarTray}}}" />
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}" Value="Vertical" />
                </MultiDataTrigger.Conditions>
                <Setter Property="MinHeight" Value="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type ToolBarTray}}}" />
            </MultiDataTrigger>
        </Style.Triggers>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:UndockableToolBar}">
                    <Border Background="Transparent" BorderThickness="0" CornerRadius="2" Margin="2" Padding="2">
                        <DockPanel LastChildFill="True">

                            <Thumb x:Name="ToolBarThumb" DockPanel.Dock="Left" Width="10" Margin="0,2,6,2" Cursor="SizeAll" ToolTip="Drag to undock">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent">
                                            <Path x:Name="GripPath" Data="M 2,2 A 1,1 0 1,1 2,2.01 M 2,6 A 1,1 0 1,1 2,6.01 M 2,10 A 1,1 0 1,1 2,10.01 M 6,2 A 1,1 0 1,1 6,2.01 M 6,6 A 1,1 0 1,1 6,6.01 M 6,10 A 1,1 0 1,1 6,10.01" 
                                  Stroke="#999" StrokeThickness="2" StrokeDashArray="0,0" Fill="#999" Stretch="None" VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType={x:Type ToolBar}}}" Value="Vertical">
                                                <Setter TargetName="GripPath" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <ToggleButton x:Name="PART_OverflowButton" DockPanel.Dock="Right" 
                          IsChecked="{Binding IsOverflowOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                          Padding="2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Path x:Name="OverflowArrow" Data="M 0,0 L 4,4 L 8,0" Stroke="#777" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2,0"/>
                            </ToggleButton>

                            <Popup x:Name="PART_OverflowPopup" AllowsTransparency="True" Placement="Bottom" 
                   PlacementTarget="{Binding ElementName=PART_OverflowButton}"
                   IsOpen="{Binding IsOverflowOpen, RelativeSource={RelativeSource TemplatedParent}}" StaysOpen="False" Focusable="False">
                                <Border Background="#FAFAFA" BorderBrush="#D4D4D4" BorderThickness="1" Padding="2" Margin="0,2,0,0">
                                    <StackPanel>

                                        <ToolBarOverflowPanel x:Name="PART_ToolBarOverflowPanel" KeyboardNavigation.TabNavigation="Cycle" KeyboardNavigation.DirectionalNavigation="Cycle" />

                                        <Separator x:Name="OverflowSeparator" Margin="0,2" Visibility="Collapsed"/>

                                        <Menu Background="Transparent" Margin="2">
                                            <MenuItem Header="Add or Remove Buttons">
                                                <MenuItem.Icon>
                                                    <Path Data="M 0,0 L 4,4 L 8,0 Z" Fill="#777" Width="6" Height="4" Stretch="Fill" VerticalAlignment="Center"/>
                                                </MenuItem.Icon>
                                                <MenuItem Header="{Binding Name}" ItemsSource="{Binding DockedItems}">
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Header" Value="{Binding Text}"/>
                                                            <Setter Property="IsCheckable" Value="True"/>
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}"/>
                                                            <Setter Property="StaysOpenOnClick" Value="True"/>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator/>

                                                <MenuItem Header="Reset Toolbar" Command="{Binding Path=MainWindow.DataContext.ResetToolbarCommand, Source={x:Static Application.Current}}" CommandParameter="{Binding}"/>

                                                <Separator/>
                                                <MenuItem Header="Customize..." Command="{Binding Path=MainWindow.DataContext.OpenCustomizeDialogCommand, Source={x:Static Application.Current}}"/>
                                            </MenuItem>
                                        </Menu>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <ToolBarPanel x:Name="PART_ToolBarPanel" IsItemsHost="True" Margin="0,0,4,0" />

                        </DockPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="HasOverflowItems" Value="True">
                            <Setter TargetName="OverflowSeparator" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <DataTrigger Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="PART_OverflowButton" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="ToolBarThumb" Property="DockPanel.Dock" Value="Top" />
                            <Setter TargetName="ToolBarThumb" Property="Width" Value="NaN" />
                            <Setter TargetName="ToolBarThumb" Property="Height" Value="10" />
                            <Setter TargetName="ToolBarThumb" Property="Margin" Value="2,0,2,6" />

                            <Setter TargetName="PART_OverflowButton" Property="DockPanel.Dock" Value="Bottom" />
                            <Setter TargetName="PART_ToolBarPanel" Property="Margin" Value="0,0,0,4" />
                            <Setter TargetName="PART_OverflowPopup" Property="Placement" Value="Right" />

                            <Setter TargetName="OverflowArrow" Property="Data" Value="M 0,0 L 4,4 L 0,8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type controls:FloatingToolBarWindow}">
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />

        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" />
        <Setter Property="BorderThickness" Value="1" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FloatingToolBarWindow}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <AdornerDecorator>
                            <ContentPresenter Margin="2"/>
                        </AdornerDecorator>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- 1. Define the Merged Dictionaries block -->
    <ResourceDictionary.MergedDictionaries>
        <!-- 2. Reference your specific control styles using Pack URIs -->
        <ResourceDictionary Source="pack://application:,,,/CommandBar.UI;component/CommandBarTemplates.xaml" />
    </ResourceDictionary.MergedDictionaries>
</ResourceDictionary>
