<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:CommandBar.UI.Controls"
	xmlns:local="clr-namespace:CommandBar.UI">
	<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
	<Style TargetType="{x:Type controls:UndockableToolBar}">

		<Style.Triggers>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True" />
					<Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}" Value="Horizontal" />
				</MultiDataTrigger.Conditions>
				<Setter Property="MinWidth" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ToolBarTray}}}" />
			</MultiDataTrigger>

			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True" />
					<Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}" Value="Vertical" />
				</MultiDataTrigger.Conditions>
				<Setter Property="MinHeight" Value="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type ToolBarTray}}}" />
			</MultiDataTrigger>
		</Style.Triggers>
		<Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type controls:UndockableToolBar}">
					<Border x:Name="RootBorder" Background="{DynamicResource CmdBar.Background}" BorderBrush="{DynamicResource CmdBar.Border}" BorderThickness="{DynamicResource CmdBar.ToolBar.BorderThickness}" CornerRadius="{DynamicResource CmdBar.ToolBar.CornerRadius}" Margin="{DynamicResource CmdBar.ToolBar.Margin}" Padding="{DynamicResource CmdBar.ToolBar.Padding}">
						<DockPanel LastChildFill="True">
                            <Thumb x:Name="ToolBarThumb" Margin="{DynamicResource CmdBar.ToolBar.Grip.Margin}" Cursor="SizeAll">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="GripBorder" 
                    Width="{DynamicResource CmdBar.ToolBar.Grip.Thickness}" 
                    Background="{DynamicResource CmdBar.ToolBar.Grip.Background}" 
                    CornerRadius="{DynamicResource CmdBar.ToolBar.Grip.CornerRadius}"
                    HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ToolBar}}" Value="Vertical">
                                                <Setter TargetName="GripBorder" Property="Width" Value="NaN" />
                                                <Setter TargetName="GripBorder" Property="Height" Value="{DynamicResource CmdBar.ToolBar.Grip.Thickness}" />
                                                <Setter TargetName="GripBorder" Property="HorizontalAlignment" Value="Stretch" />
                                                <Setter TargetName="GripBorder" Property="VerticalAlignment" Value="Center" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <ToggleButton x:Name="PART_OverflowButton" DockPanel.Dock="Right" 
			  IsChecked="{Binding IsOverflowOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
			  Padding="4,2" Margin="2,0" Cursor="Hand" 
			  Background="Transparent" 
			  BorderBrush="Transparent" 
			  BorderThickness="1">
								<ToggleButton.Template>
									<ControlTemplate TargetType="ToggleButton">
										<Border x:Name="RootBorder" 
					Background="{TemplateBinding Background}" 
					BorderBrush="{TemplateBinding BorderBrush}"
					BorderThickness="{TemplateBinding BorderThickness}"
					CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
										</Border>

										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
												<Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Hover.Border}"/>
											</Trigger>
											<Trigger Property="IsChecked" Value="True">
												<Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
												<Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource CmdBar.Button.Checked.Border}"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</ToggleButton.Template>

								<Path x:Name="OverflowArrow" 
		  Data="{DynamicResource CmdBar.ToolBar.OverflowIcon.Horizontal}" 
		  Stroke="{DynamicResource CmdBar.Foreground}" 
		  StrokeThickness="2" 
		  VerticalAlignment="Center" 
		  HorizontalAlignment="Center"/>
							</ToggleButton>

							<Popup x:Name="PART_OverflowPopup" AllowsTransparency="True" Placement="Bottom" 
	   PlacementTarget="{Binding ElementName=PART_OverflowButton}"
	   VerticalOffset="{DynamicResource CmdBar.Menu.PopupOffset}"
	   IsOpen="{Binding IsOverflowOpen, RelativeSource={RelativeSource TemplatedParent}}" 
	   StaysOpen="False" Focusable="False">

								<Border Background="{DynamicResource CmdBar.Background}" 
			BorderBrush="{DynamicResource CmdBar.Border}" 
			BorderThickness="1" 
			Padding="2"
			CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}"
			Margin="{DynamicResource CmdBar.Menu.ShadowMargin}"
			Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">

									<StackPanel>

										<ToolBarOverflowPanel x:Name="PART_ToolBarOverflowPanel" 
								  KeyboardNavigation.TabNavigation="Cycle" 
								  KeyboardNavigation.DirectionalNavigation="Cycle" />

										<Separator x:Name="OverflowSeparator" Margin="0,2" Visibility="Collapsed" Background="{DynamicResource CmdBar.Border}"/>

                                        <Menu Background="Transparent" Margin="2">
                                            <Menu.Resources>
                                                <Style TargetType="MenuItem">
                                                    <Style.Triggers>

                                                        <Trigger Property="Role" Value="TopLevelHeader">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="MenuItem">
                                                                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" Margin="2,1">
                                                                            <Grid Margin="4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="24" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="14" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"/>
                                                                                <Path x:Name="SubmenuArrow" Grid.Column="2" Data="M 0,0 L 4,4 L 0,8 Z" Fill="{DynamicResource CmdBar.Foreground}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>

                                                                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right" VerticalOffset="-4" HorizontalOffset="{DynamicResource CmdBar.Menu.PopupOffset}" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">
                                                                                    <Border Background="{DynamicResource CmdBar.Background}" BorderBrush="{DynamicResource CmdBar.Border}" BorderThickness="1" CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}" Padding="2" Margin="{DynamicResource CmdBar.Menu.ShadowMargin}" Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">
                                                                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
                                                                                            <ItemsPresenter />
                                                                                        </ScrollViewer>
                                                                                    </Border>
                                                                                </Popup>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSubmenuOpen" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>

                                                        <Trigger Property="Role" Value="SubmenuHeader">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="MenuItem">
                                                                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" Margin="2,1">
                                                                            <Grid Margin="4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="24" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="14" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter ContentSource="Icon" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"/>
                                                                                <Path x:Name="SubmenuArrow" Grid.Column="2" Data="M 0,0 L 4,4 L 0,8 Z" Fill="{DynamicResource CmdBar.Foreground}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>

                                                                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right" VerticalOffset="-4" HorizontalOffset="{DynamicResource CmdBar.Menu.PopupOffset}" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False">
                                                                                    <Border Background="{DynamicResource CmdBar.Background}" BorderBrush="{DynamicResource CmdBar.Border}" BorderThickness="1" CornerRadius="{DynamicResource CmdBar.Menu.CornerRadius}" Padding="2" Margin="{DynamicResource CmdBar.Menu.ShadowMargin}" Effect="{DynamicResource CmdBar.Menu.Shadow}" MinWidth="{DynamicResource CmdBar.Menu.MinWidth}">
                                                                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
                                                                                            <ItemsPresenter />
                                                                                        </ScrollViewer>
                                                                                    </Border>
                                                                                </Popup>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSubmenuOpen" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Checked.Background}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>

                                                        <Trigger Property="Role" Value="SubmenuItem">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="MenuItem">
                                                                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="{DynamicResource CmdBar.Button.CornerRadius}" Margin="2,1">
                                                                            <Grid Margin="4">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="24" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>

                                                                                <Grid Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                    <ContentPresenter ContentSource="Icon"/>
                                                                                    <Path x:Name="CheckMark" Data="M 2,7 L 5,10 L 11,3" Stroke="{DynamicResource CmdBar.Foreground}" StrokeThickness="1.5" StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                </Grid>

                                                                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CmdBar.Button.Hover.Background}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.5"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>

                                                <Style TargetType="Separator">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Separator">
                                                                <Rectangle Height="1" Fill="{DynamicResource CmdBar.Border}" Margin="32,2,2,2"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Menu.Resources>

                                            <MenuItem Header="Add or Remove Buttons">
                                                <MenuItem Header="{Binding Name}" ItemsSource="{Binding DockedItems}">
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Header" Value="{Binding Text}"/>
                                                            <Setter Property="IsCheckable" Value="True"/>
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}"/>
                                                            <Setter Property="StaysOpenOnClick" Value="True"/>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>

                                                <Separator/>
                                                <MenuItem Header="Reset Toolbar" Command="{Binding Path=MainWindow.DataContext.ResetToolbarCommand, Source={x:Static Application.Current}}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Customize..." Command="{Binding Path=MainWindow.DataContext.OpenCustomizeDialogCommand, Source={x:Static Application.Current}}"/>
                                            </MenuItem>
                                        </Menu>

                                    </StackPanel>
								</Border>
							</Popup>

							<ToolBarPanel x:Name="PART_ToolBarPanel" IsItemsHost="True" Margin="0,0,4,0" />

						</DockPanel>
					</Border>

					<ControlTemplate.Triggers>
						<Trigger Property="HasOverflowItems" Value="True">
							<Setter TargetName="OverflowSeparator" Property="Visibility" Value="Visible" />
						</Trigger>

						<DataTrigger Binding="{Binding IsMenuBar, RelativeSource={RelativeSource Self}}" Value="True">
							<Setter TargetName="PART_OverflowButton" Property="Visibility" Value="Collapsed" />
							<Setter TargetName="RootBorder" Property="BorderThickness" Value="0" />
							<Setter TargetName="RootBorder" Property="Margin" Value="0" />
						</DataTrigger>

						<DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToolBarTray}}}" Value="{x:Null}">
							<Setter TargetName="RootBorder" Property="BorderThickness" Value="0" />
							<Setter TargetName="RootBorder" Property="Margin" Value="0" />
							<Setter TargetName="RootBorder" Property="CornerRadius" Value="0" />
						</DataTrigger>

						<Trigger Property="Orientation" Value="Vertical">
							<Setter TargetName="ToolBarThumb" Property="DockPanel.Dock" Value="Top" />
							<Setter TargetName="ToolBarThumb" Property="Width" Value="NaN" />
							<Setter TargetName="ToolBarThumb" Property="Height" Value="10" />
							<Setter TargetName="ToolBarThumb" Property="Margin" Value="2,0,2,6" />

							<Setter TargetName="PART_OverflowButton" Property="DockPanel.Dock" Value="Bottom" />
							<Setter TargetName="PART_ToolBarPanel" Property="Margin" Value="0,0,0,4" />
							<Setter TargetName="PART_OverflowPopup" Property="Placement" Value="Right" />

							<Setter TargetName="OverflowArrow" Property="Data" Value="{DynamicResource CmdBar.ToolBar.OverflowIcon.Vertical}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style TargetType="{x:Type controls:FloatingToolBarWindow}">
		<Setter Property="WindowStyle" Value="None" />
		<Setter Property="AllowsTransparency" Value="True" />
		<Setter Property="SizeToContent" Value="WidthAndHeight" />

		<Setter Property="Background" Value="{DynamicResource CmdBar.Background}" />
		<Setter Property="BorderBrush" Value="{DynamicResource CmdBar.Border}" />
		<Setter Property="BorderThickness" Value="1" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type controls:FloatingToolBarWindow}">
					<Border Background="{TemplateBinding Background}" 
		BorderBrush="{TemplateBinding BorderBrush}" 
		BorderThickness="{TemplateBinding BorderThickness}"
		CornerRadius="{DynamicResource CmdBar.Window.CornerRadius}">
						<AdornerDecorator>
							<ContentPresenter Margin="2"/>
						</AdornerDecorator>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<!-- 1. Define the Merged Dictionaries block -->
</ResourceDictionary>
