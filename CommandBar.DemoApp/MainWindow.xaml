<Window x:Class="CommandBar.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommandBar.DemoApp"
        xmlns:controls="clr-namespace:CommandBar.UI.Controls;assembly=CommandBar.UI"
        Title="Undockable CommandBar Test" Height="450" Width="800">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid>
        <DockPanel>

            <controls:UndockableToolBar DockPanel.Dock="Top" 
                                        ItemsSource="{Binding MainToolbar.DockedItems}" />

            <TextBox AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Text="Type your document here..." 
                     Margin="10" 
                     FontFamily="Consolas" 
                     FontSize="14"/>

        </DockPanel>
    </Grid>
</Window>
