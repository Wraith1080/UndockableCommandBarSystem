<Window x:Class="CommandBar.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CommandBar.DemoApp"
        xmlns:controls="clr-namespace:CommandBar.UI.Controls;assembly=CommandBar.UI"
        Title="Undockable CommandBar System" Height="600" Width="900">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid>
        <DockPanel>
            <ToolBarTray DockPanel.Dock="Top" Background="#F3F3F3">

                <controls:UndockableToolBar Band="0" BandIndex="0" 
                                            ItemsSource="{Binding MainToolbar.DockedItems}" />

                <controls:UndockableToolBar Band="0" BandIndex="1" 
                                            ItemsSource="{Binding FormattingToolbar.DockedItems}" />

            </ToolBarTray>

            <TextBox AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Text="Type your document here..." 
                     Margin="10" 
                     FontFamily="Consolas" 
                     FontSize="14"/>
        </DockPanel>
    </Grid>
</Window>